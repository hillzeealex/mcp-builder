{
  "name": "@mcp-builder/core",
  "version": "0.1.0",
  "description": "Pure, deterministic generator that turns a typed MCP server definition into project files.",
  "type": "module",
  "license": "MIT",
  "author": "Alexander Hills",
  "keywords": ["mcp", "model-context-protocol", "claude", "code-generator", "zod"],
  "homepage": "https://github.com/hillzeealex/mcp-builder#readme",
  "bugs": "https://github.com/hillzeealex/mcp-builder/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hillzeealex/mcp-builder.git",
    "directory": "packages/core"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "jiti": "^2.4.2",
    "prettier": "^3.4.2",
    "yaml": "^2.6.1",
    "zod": "^3.25.76"
  }
}
